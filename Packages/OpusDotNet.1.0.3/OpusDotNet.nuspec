<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>OpusDotNet</id>
    <version>1.0.3</version>
    <authors>mrphil2105</authors>
    <owners>mrphil2105</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <projectUrl>https://github.com/mrphil2105/OpusDotNet</projectUrl>
    <description>An easy-to-use library for encoding and decoding 16-bit audio using the Opus Audio Codec. NOTE: This library is a wrapper around the official libopus, and does not contain code for parsing .opus container files.</description>
    <releaseNotes>Added improved encode and decode methods. IMPORTANT: Deprecated the old encode and decode methods.</releaseNotes>
    <copyright>Copyright © 2019 mrphil2105</copyright>
    <tags>Opus, Audio, Codec, Encoder, Decoder, VoIP</tags>
    <dependencies>
      <dependency id="OpusDotNet.opus.win-x86" version="1.3.1" />
      <dependency id="OpusDotNet.opus.win-x64" version="1.3.1" />
    </dependencies>
  </metadata>
</package>